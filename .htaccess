# MEDUSSA - Apache Configuration
Options -Indexes
DirectoryIndex index.php

# Protect files
<Files "*.php">
    Order Allow,Deny
    Allow from all
</Files>

# Disable directory listing
Options -Indexes

# Clean URLs
RewriteEngine On
RewriteRule ^download/([0-9]{4}-[0-9]{2}-[0-9]{2})$ download.php?date=$1 [L]

# No cache for JSON
<Files "*.json">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires 0
</Files>
