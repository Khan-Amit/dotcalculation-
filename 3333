        }
        @media (max-width: 480px) {
            .stats-grid { grid-template-columns: repeat(2, 1fr); }
            .node-grid { grid-template-columns: repeat(3, 1fr); }
            .rolling-window { max-height: 250px; }
            .rolling-window .window-content .block-line {
                grid-template-columns: 20px 40px 30px 50px 40px 30px 30px;
                font-size: 7px;
                gap: 2px;
            }
        }
    </style>
