        /* ============================================================
        SCROLLBAR
        ============================================================ */
        .rolling-window::-webkit-scrollbar { width: 4px; }
        .rolling-window::-webkit-scrollbar-track { background: #0a0a0f; }
        .rolling-window::-webkit-scrollbar-thumb { background: #ffaa0033; border-radius: 2px; }

        /* ============================================================
        ANIMATIONS
        ============================================================ */
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        @keyframes speedPulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.7; transform: scale(1.05); }
        }
        @keyframes securePulse {
            0%, 100% { opacity: 1; text-shadow: 0 0 20px #00ff8844; }
            50% { opacity: 0.7; text-shadow: 0 0 40px #00ff8888; }
        }

        /* ============================================================
        RESPONSIVE
        ============================================================ */
        @media (max-width: 992px) {
            .dial-heat-grid { grid-template-columns: 1fr; }
            .node-grid { grid-template-columns: repeat(3, 1fr); }
            .stats-grid { grid-template-columns: repeat(3, 1fr); }
        }
        @media (max-width: 768px) {
            .stats-grid { grid-template-columns: repeat(3, 1fr); }
            .node-grid { grid-template-columns: repeat(3, 1fr); }
            .rolling-window .window-content .block-line {
                grid-template-columns: 30px 50px 40px 60px 50px 40px 40px;
