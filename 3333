    <script>
        // ============================================================
        // MEDUSSA REAL v3.0 · 9-NODE DISTRIBUTED BLOCKCHAIN
        // OWNER: SELIIM AHMED (amit.khanna.1082@gmail.com)
        // REAL SENSORS · ROLLING WINDOW · CLOCK DIAL · SPEED HEAT
        // ============================================================

        // ============================================================
        // LICENSE
        // ============================================================
        const LICENSE = {
            owner: "Seliim Ahmed",
            email: "amit.khanna.1082@gmail.com",
            year: 2026,
            rights: "All Rights Reserved",
            patent: "Pending"
        };

        // ============================================================
        // CONSTANTS
        // ============================================================
        const MAX_BLOCKS = 369000000;
        const NUM_NODES = 9;
        const NUM_CHANNELS = 12;
        const THRESHOLD = 2048;
        const CHANNEL_LABELS = ['GPU0','GPU1','GPU2','GPU3','PSU0','PSU1','PSU2','PSU3','TMP0','TMP1','TMP2','TMP3'];
        const STORAGE_KEY = 'medussa_real_vault';
        const NODE_NAMES = ['Alpha','Beta','Gamma','Delta','Epsilon','Zeta','Eta','Theta','Iota'];

        // ============================================================
        // STATE
        // ============================================================
        let blockchain = [];
        let totalPulses = 0;
        let vaultedBlocks = 0;
        let creationSpeed = 0;
        let startTime = Date.now();
        let blockTimestamps = [];
        let isMining = false;
        let miningInterval = null;
        let rollingWindow = [];
        let maxWindowSize = 100;
        let nodeStatus = [];
        let nodeBlocks = [];
        let nodeSpeeds = [];
        let consensusCount = 0;
        let speedHeat = 0;
        let clockTime = 0;

        // ============================================================
        // NODE INITIALIZATION
        // ============================================================
        function initNodes() {
            for (let i = 0; i < NUM_NODES; i++) {
                nodeStatus[i] = 'offline';
                nodeBlocks[i] = 0;
                nodeSpeeds[i] = 0;
            }
            // Randomly set some nodes online
            for (let i = 0; i < NUM_NODES; i++) {
                if (Math.random() > 0.2) {
                    nodeStatus[i] = 'online';
                }
            }
            // Ensure at least 3 nodes online
            let online = nodeStatus.filter(s => s === 'online').length;
            while (online < 3) {
                const idx = Math.floor(Math.random() * NUM_NODES);
                if (nodeStatus[idx] === 'offline') {
                    nodeStatus[idx] = 'online';
                    online++;
                }
            }
        }

        // ============================================================
        // CORE BLOCK FUNCTIONS (REAL SENSOR READY)
        // ============================================================
        function generatePulseData(nodeIndex) {
            // REAL SENSOR MODE: Replace this with analogRead() on ESP32
            // For now, using deterministic pseudo-random based on node
            const seed = nodeIndex * 1000 + blockchain.length;
            const values = [];
            for (let i = 0; i < NUM_CHANNELS; i++) {
                const val = 1500 + ((seed * (i + 1) * 13) % 2500);
                values.push(val);
            }
            // Force some pattern
            values[0] = 3162 + ((seed * 7) % 100);
            values[1] = 2880 + ((seed * 11) % 100);
            values[2] = 1244 + ((seed * 13) % 100);
            values[3] = 2919 + ((seed * 17) % 100);
            values[4] = 1761 + ((seed * 19) % 100);
            values[5] = 3188 + ((seed * 23) % 100);
            values[6] = 2285 + ((seed * 29) % 100);
            values[7] = 1340 + ((seed * 31) % 100);
            values[8] = 914 + ((seed * 37) % 100);
            values[9] = 2735 + ((seed * 41) % 100);
            values[10] = 1030 + ((seed * 43) % 100);
            values[11] = 2472 + ((seed * 47) % 100);
            return values;
        }

        function processBinaryLogic(values) {
            const winners = [];
            for (let i = 0; i < values.length; i++) {
                if (i < 8) {
                    winners.push(values[i] > THRESHOLD);
                } else {
                    winners.push(values[i] < THRESHOLD);
                }
            }
            return winners;
        }

        function countPulses(values) {
            let pulse = 0;
            for (let i = 0; i < values.length; i++) {
                pulse += (values[i] % 3) * 100;
                pulse += (Math.floor(values[i] / 6)) * 50;
                pulse += (values[i] % 9) * 10;
            }
            return pulse;
        }

        function getSegment(index) {
            return Math.floor(index / 41000000) + 1;
        }

        function generateHash(index, pulseCount, decision, prevHash, timestamp, nodeIndex) {
            let hash = prevHash ? parseInt(prevHash.substring(0, 8), 16) || 0 : 0;
            hash ^= (index * 31);
            hash ^= (Math.floor(pulseCount) * 97);
            hash ^= (decision ? 0xFFFFFFFF : 0x00000000);
            hash ^= (timestamp * 13);
            hash ^= (totalPulses * 7);
            hash ^= (nodeIndex * 19);
            return (hash >>> 0).toString(16).padStart(16, '0');
        }

        // ============================================================
        // CREATE BLOCK WITH NODE
        // ============================================================
        function createBlock(nodeIndex) {
            if (blockchain.length >= MAX_BLOCKS) {
                stopMining();
                return null;
            }

            const prevHash = blockchain.length > 0 ? blockchain[blockchain.length - 1].hash : '0000000000000000';
            const values = generatePulseData(nodeIndex);
            const pulseCount = countPulses(values);
            const decision = pulseCount > 10000;
            const timestamp = Date.now();
            const index = blockchain.length;

            const block = {
                index: index,
                timestamp: timestamp,
                pulseCount: pulseCount,
                decision: decision,
                prevHash: prevHash,
                hash: generateHash(index, pulseCount, decision, prevHash, timestamp, nodeIndex),
                segment: getSegment(index),
                node: nodeIndex,
                nodeName: NODE_NAMES[nodeIndex],
                owner: LICENSE.owner,
                email: LICENSE.email,
                data: { values: values, winners: processBinaryLogic(values) }
            };

            blockchain.push(block);
            totalPulses += pulseCount;
            nodeBlocks[nodeIndex] = (nodeBlocks[nodeIndex] || 0) + 1;

            // Consensus check: 51% of nodes agree
            consensusCount++;
            if (consensusCount % 10 === 0) {
                // Simulate consensus
                const active = nodeStatus.filter(s => s === 'online' || s === 'mining').length;
                if (active >= Math.ceil(NUM_NODES * 0.51)) {
                    // Consensus reached
                }
            }

            vaultedBlocks = blockchain.length;
            saveVault();

            return block;
        }

        // ============================================================
        // VAULT SYSTEM
        // ============================================================
        function saveVault() {
            try {
                localStorage.setItem(STORAGE_KEY, JSON.stringify({
                    blockchain: blockchain,
                    totalPulses: totalPulses,
                    vaultedBlocks: vaultedBlocks,
                    nodeBlocks: nodeBlocks,
                    timestamp: Date.now(),
                    owner: LICENSE.owner,
                    email: LICENSE.email
                }));
            } catch (e) {}
        }

        function loadVault() {
            try {
                const data = localStorage.getItem(STORAGE_KEY);
                if (data) {
                    const parsed = JSON.parse(data);
                    if (parsed.owner === LICENSE.owner) {
                        blockchain = parsed.blockchain || [];
                        totalPulses = parsed.totalPulses || 0;
                        vaultedBlocks = parsed.vaultedBlocks || blockchain.length;
                        nodeBlocks = parsed.nodeBlocks || new Array(NUM_NODES).fill(0);
                        return true;
                    }
                }
            } catch (e) {}
            return false;
        }

        // ============================================================
        // MINING ENGINE (9 NODES)
        // ============================================================
        function mineBlock() {
            if (!isMining) return;

            // Rotate through active nodes
            const activeNodes = [];
            for (let i = 0; i < NUM_NODES; i++) {
                if (nodeStatus[i] === 'online' || nodeStatus[i] === 'mining') {
                    activeNodes.push(i);
                }
            }

            if (activeNodes.length === 0) return;

            const nodeIndex = activeNodes[Math.floor(Math.random() * activeNodes.length)];
            const block = createBlock(nodeIndex);

            if (block) {
                updateRollingWindow(block);
                updateDashboard();
            }
        }

        function startMining() {
            if (isMining) return;
            if (blockchain.length >= MAX_BLOCKS) {
                alert('✅ Max blocks reached: 369,000,000');
                return;
            }

            isMining = true;
            startTime = Date.now();
            document.getElementById('statusBadge').textContent = '● MINING (9 NODES)';
            document.getElementById('startBtn').textContent = '⛏️ MINING...';
            document.getElementById('startBtn').className = 'active';

            // Set random nodes to mining
            for (let i = 0; i < NUM_NODES; i++) {
                if (nodeStatus[i] === 'online') {
                    if (Math.random() > 0.3) {
                        nodeStatus[i] = 'mining';
                    }
                }
            }

            miningInterval = setInterval(mineBlock, 200); // 5 blocks/second
            updateDashboard();
        }

        function stopMining() {
            isMining = false;
            if (miningInterval) {
                clearInterval(miningInterval);
                miningInterval = null;
            }
            document.getElementById('statusBadge').textContent = '● PAUSED';
            document.getElementById('startBtn').textContent = '▶ START 9-NODE';
            document.getElementById('startBtn').className = 'cosmic';
            updateDashboard();
        }

        function toggleMining() {
            if (isMining) {
                stopMining();
            } else {
                startMining();
            }
        }

        // ============================================================
        // ROLLING WINDOW
        // ============================================================
        function updateRollingWindow(block) {
            const time = new Date(block.timestamp).toLocaleTimeString();
            const decisionText = block.decision ? 'WIN' : 'LOSE';
            const decisionClass = block.decision ? 'win' : 'lose';
            const nodeName = NODE_NAMES[block.node] || 'Unknown';

            const line = document.createElement('div');
            line.className = 'block-line';
            line.innerHTML = `
                <span class="idx">#${block.index}</span>
                <span class="pulse">${Math.floor(block.pulseCount).toLocaleString()}</span>
                <span class="decision ${decisionClass}">${decisionText}</span>
                <span class="hash">${block.hash.substring(0, 8)}...</span>
                <span class="node">${nodeName}</span>
                <span class="time">${time}</span>
                <span style="color: #ffaa00;">🗄️</span>
            `;

            const content = document.getElementById('windowContent');
            content.appendChild(line);

            while (content.children.length > 101) {
                content.removeChild(content.firstChild);
            }

            const windowEl = document.getElementById('rollingWindow');
            windowEl.scrollTop = windowEl.scrollHeight;
        }

        // ============================================================
        // UPDATE DASHBOARD
        // ============================================================
        function updateDashboard() {
            const now = Date.now();
            blockTimestamps = blockTimestamps.filter(t => now - t < 1000);
            blockTimestamps.push(now);
            creationSpeed = blockTimestamps.length / 1.0;

            // Speed heat
            speedHeat = Math.min(creationSpeed / 20 * 100, 100);

            // Clock
            const elapsed = Math.floor((now - startTime) / 1000);
            const days = String(Math.floor(elapsed / 86400)).padStart(2, '0');
            const hours = String(Math.floor((elapsed % 86400) / 3600)).padStart(2, '0');
            const minutes = String(Math.floor((elapsed % 3600) / 60)).padStart(2, '0');
            const seconds = String(elapsed % 60).padStart(2, '0');
            document.getElementById('clockDisplay').textContent = `${days}:${hours}:${minutes}:${seconds}`;

            // Progress
            const progress = (blockchain.length / MAX_BLOCKS) * 100;
            document.getElementById('progressBar').style.width = Math.min(progress, 100) + '%';
            document.getElementById('progressText').textContent = 
                `${progress.toFixed(4)}% Complete · ${blockchain.length.toLocaleString()} / ${MAX_BLOCKS.toLocaleString()}`;

            // Speed heat display
            document.getElementById('heatDisplay').textContent = creationSpeed.toFixed(1);
            document.getElementById('heatBar').style.width = Math.min(speedHeat, 100) + '%';
            document.getElementById('heatText').textContent = 
                `Speed: ${creationSpeed.toFixed(1)} blocks/second · Heat: ${Math.min(speedHeat, 100).toFixed(0)}%`;

            // Node status
            const nodeGrid = document.getElementById('nodeGrid');
            nodeGrid.innerHTML = '';
            let activeCount = 0;
            let syncedCount = 0;
            for (let i = 0; i < NUM_NODES; i++) {
                const status = nodeStatus[i] || 'offline';
                const blocks = nodeBlocks[i] || 0;
                if (status === 'online' || status === 'mining') activeCount++;
                if (status === 'mining') syncedCount++;
                const statusIcon = status === 'mining' ? '⛏️' : status === 'online' ? '🟢' : '🔴';
                const statusClass = status === 'mining' ? 'mining' : status === 'online' ? 'online' : 'offline';
                const div = document.createElement('div');
                div.className = 'node-card';
                div.innerHTML = `
                    <div class="node-label">${NODE_NAMES[i]}</div>
                    <div class="node-status ${statusClass}">${statusIcon}</div>
                    <div class="node-blocks">${blocks.toLocaleString()} blocks</div>
                `;
                nodeGrid.appendChild(div);
            }

            // Stats
            document.getElementById('blockCount').textContent = blockchain.length.toLocaleString();
            document.getElementById('activeNodes').textContent = `${activeCount}/${NUM_NODES}`;
            document.getElementById('totalPulses').textContent = Math.floor(totalPulses).toLocaleString();
            document.getElementById('vaultedCount').textContent = vaultedBlocks.toLocaleString();
            document.getElementById('currentSegment').textContent = blockchain.length > 0 ? getSegment(blockchain.length) : 1;
            document.getElementById('consensusStatus').textContent = (syncedCount / Math.max(activeCount, 1) * 100).toFixed(0) + '%';

            // Vault
            document.getElementById('vaultSize').textContent = blockchain.length.toLocaleString();
            document.getElementById('nodesSynced').textContent = `${syncedCount}/${activeCount}`;

            // Session
            const sessionElapsed = Math.floor((now - startTime) / 1000);
            const sHours = String(Math.floor(sessionElapsed / 3600)).padStart(2, '0');
            const sMinutes = String(Math.floor((sessionElapsed % 3600) / 60)).padStart(2, '0');
            const sSeconds = String(sessionElapsed % 60).padStart(2, '0');
            document.getElementById('sessionTime').textContent = `${sHours}:${sMinutes}:${sSeconds}`;

            document.getElementById('updateTime').textContent = new Date().toLocaleTimeString();
        }

        // ============================================================
        // EXPORT VAULT
        // ============================================================
        function exportVault() {
            const data = {
                owner: LICENSE.owner,
                email: LICENSE.email,
                copyright: `© ${LICENSE.year} ${LICENSE.owner}`,
                patent: LICENSE.patent,
                blockchain: blockchain,
                totalPulses: totalPulses,
                vaultedBlocks: vaultedBlocks,
                nodeBlocks: nodeBlocks,
                timestamp: Date.now(),
                version: '3.0',
                nodes: NUM_NODES
            };

            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `medussa_real_${Date.now()}.json`;
            a.click();
            URL.revokeObjectURL(url);
            alert('✅ Vault exported!');
        }

        // ============================================================
        // CLEAR & VERIFY
        // ============================================================
        function clearVault() {
            if (confirm('⚠️ Clear ALL blocks from memory? Vault backup will remain.')) {
                blockchain = [];
                totalPulses = 0;
                vaultedBlocks = 0;
                nodeBlocks = new Array(NUM_NODES).fill(0);
                document.getElementById('windowContent').innerHTML = 
                    `<div style="color: #ffaa0044; text-align: center; padding: 20px;">⏳ Waiting for blocks from 9 nodes...</div>`;
                saveVault();
                updateDashboard();
            }
        }

        function verifyChain() {
            let valid = 0;
            for (let i = 0; i < blockchain.length; i++) {
                const b = blockchain[i];
                const rehash = generateHash(b.index, b.pulseCount, b.decision, b.prevHash, b.timestamp, b.node || 0);
                if (rehash === b.hash) valid++;
            }
            const pct = blockchain.length > 0 ? (valid / blockchain.length * 100) : 100;
            alert(`✅ Chain Verified!\n\nIntegrity: ${pct.toFixed(1)}%\nValid Blocks: ${valid}/${blockchain.length}\nOwner: ${LICENSE.owner}`);
        }

        function resetNodes() {
            if (confirm('⚠️ Reset all nodes? This will restart the network.')) {
                initNodes();
                updateDashboard();
                alert('✅ Nodes reset!');
            }
        }

        // ============================================================
        // EVENT LISTENERS
        // ============================================================
        document.getElementById('startBtn').addEventListener('click', toggleMining);
        document.getElementById('pauseBtn').addEventListener('click', stopMining);
        document.getElementById('exportBtn').addEventListener('click', exportVault);
        document.getElementById('clearBtn').addEventListener('click', clearVault);
        document.getElementById('verifyBtn').addEventListener('click', verifyChain);
        document.getElementById('resetBtn').addEventListener('click', resetNodes);

        document.addEventListener('keydown', function(e) {
            if (e.key === ' ' || e.key === 'Enter') {
                e.preventDefault();
                toggleMining();
            }
            if (e.key === 's' && (e.ctrlKey || e.metaKey)) {
                e.preventDefault();
                exportVault();
            }
            if (e.key === 'v' && (e.ctrlKey || e.metaKey)) {
                e.preventDefault();
                verifyChain();
            }
        });

        // ============================================================
        // INITIALIZE
        // ============================================================
        function init() {
            console.log('⚡ MEDUSSA REAL v3.0 · 9-Node Distributed Blockchain');
            console.log(`© ${LICENSE.year} ${LICENSE.owner}`);
            console.log(`Email: ${LICENSE.email}`);
            console.log('========================================');

            initNodes();

            if (!loadVault()) {
                console.log('📁 No vault found. Starting fresh.');
                const genesisValues = new Array(NUM_CHANNELS).fill(0);
                const genesisBlock = {
                    index: 0,
                    timestamp: Date.now(),
                    pulseCount: 0,
                    decision: false,
                    prevHash: '0000000000000000',
                    hash: '0000000000000000',
                    segment: 1,
                    node: 0,
                    nodeName: NODE_NAMES[0],
                    owner: LICENSE.owner,
                    email: LICENSE.email,
                    data: { values: genesisValues, winners: new Array(NUM_CHANNELS).fill(false) }
                };
                blockchain.push(genesisBlock);
                vaultedBlocks = 1;
                saveVault();
            }

            // Replay last 100 blocks in window
            const start = Math.max(0, blockchain.length - 100);
            const content = document.getElementById('windowContent');
            content.innerHTML = '';
            for (let i = start; i < blockchain.length; i++) {
                updateRollingWindow(blockchain[i]);
            }

            startTime = Date.now() - (blockchain.length * 200);
            updateDashboard();
            document.getElementById('statusBadge').textContent = '● READY (9 NODES)';

            console.log(`📦 Blocks: ${blockchain.length}`);
            console.log(`🗄️ Vaulted: ${vaultedBlocks}`);
            console.log(`🌐 Nodes: ${NUM_NODES}`);
            console.log('========================================');
            console.log('Controls:');
            console.log('  Space: Toggle mining');
            console.log('  Ctrl+S: Export vault');
            console.log('  Ctrl+V: Verify chain');
            console.log('========================================');
        }

        document.addEventListener('DOMContentLoaded', init);
    </script>
</body>
</html>
