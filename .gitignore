# ============================================
# MEDUSA - Gitignore
# ============================================

# Node Modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# MEDUSA Backup Files (Keep structure, ignore data)
medusa_backups/
*.json
!medusa_backups/.gitkeep

# Environment Files
.env
.env.local
.env.*.local

# Logs
logs/
*.log
*.log.*

# OS Files
.DS_Store
Thumbs.db
desktop.ini

# IDE Files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Build Files
dist/
build/
*.min.js
*.min.css

# Temporary Files
tmp/
temp/
*.tmp
*.temp

# Coverage
coverage/
.nyc_output/

# Misc
*.pid
*.seed
*.pid.lock
