# MEDUSSA SECURE .gitignore

# Temporary files
*.tmp
*.temp
*.log
*.bak
*.old
*.orig

# IDE files
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
.vs/

# Build files
*.exe
*.out
*.app
*.dll
*.so
*.dylib

# Environment
.env
.env.local

# Keep essential files
!medussa_security.html
!LICENSE.md
!README.md
!*.html
!*.md

# Chain backups (optional)
*.json
!package.json
