# ============================================================
# .gitignore — MEDUSSA REAL BLOCKCHAIN
# Purpose: Prevent conflicts with other codebases
# ============================================================

# ============================================================
# BLOCKCHAIN DATA (CRITICAL — IGNORE TO AVOID CONFLICTS)
# ============================================================
blockchain.json
*.json
!package.json
!package-lock.json
!tsconfig.json

# ============================================================
# OS FILES
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.tmp
*.temp
*.bak
*.backup
*.swp
*.swo
*~

# ============================================================
# EDITOR & IDE
# ============================================================
.vscode/
.idea/
*.iml
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ============================================================
# DEPENDENCIES (if any)
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================================
# ENVIRONMENT & SECRETS
# ============================================================
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
*.p12

# ============================================================
# BUILD / DIST
# ============================================================
dist/
build/
out/
*.min.js
*.min.css
*.map

# ============================================================
# LOGS
# ============================================================
logs/
*.log
access.log
error.log

# ============================================================
# USER-SPECIFIC FILES
# ============================================================
*.user
*.user.*
*.orig

# ============================================================
# TEMP FILES (auto-generated by browser/editor)
# ============================================================
*.cache
*.tmp
*.temp
*.swp
*.swo
*~
.DS_Store

# ============================================================
# MEDUSSA SPECIFIC — PREVENT MERGE CONFLICTS
# ============================================================
# Ignore all JSON files except the ones we explicitly want
*.json
!package.json
!tsconfig.json
!manifest.json

# Ignore any local vault exports
medussa-vault-*.json
vault-*.json

# Ignore any backup copies
blockchain-backup-*.json
chain-backup-*.json
